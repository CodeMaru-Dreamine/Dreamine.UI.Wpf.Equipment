<Window
    x:Class="Dreamine.UI.Wpf.Equipment.Popup.DreamineBlinkPopupWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:converters="clr-namespace:VsLibrary.UiComponent.Converters"
    xmlns:i="http://schemas.microsoft.com/xaml/behaviors"
    xmlns:vsmvvm="clr-namespace:VsLibrary.Common.MVVM.Behaviors"
    Title="Blink Popup"
    AllowsTransparency="True"
    Background="Transparent"
    FocusManager.FocusedElement="{Binding ElementName=OkButton}"
    ResizeMode="NoResize"
    ShowInTaskbar="False"
    WindowStyle="None">

    <!--  Enter / Esc 기본 키 바인딩  -->
    <Window.InputBindings>
        <KeyBinding Key="Enter" Command="{Binding OkCommand}" />
        <KeyBinding Key="Escape" Command="{Binding CancelCommand}" />
    </Window.InputBindings>

    <Window.Resources>
        <!--  깜빡임 대상 브러시: Color 바인딩  -->
        <SolidColorBrush x:Key="RootBrush" Color="{Binding RootColor1}" />
        <!--  전경(텍스트) 색 바인딩  -->
        <SolidColorBrush x:Key="RootForeground" Color="{Binding ForegroundColor}" />

        <!--  Bool → Visibility 컨버터  -->
        <BooleanToVisibilityConverter x:Key="BoolToVisibility" />
        <converters:InverseBoolToVisibilityConverter x:Key="InverseBoolToVisibility" />
    </Window.Resources>

    <!--  전체 화면 오버레이 영역  -->
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="40" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!--  상단 바(드래그 가능)  -->
        <Grid Grid.Row="0" Background="#2C3E50">
            <i:Interaction.Behaviors>
                <vsmvvm:WindowDragBehavior IsDragEnabled="True" />
            </i:Interaction.Behaviors>

            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <TextBlock
                Margin="10,0"
                VerticalAlignment="Center"
                Foreground="White"
                Text="✅" />

            <TextBlock
                Grid.Column="1"
                Margin="6,0"
                VerticalAlignment="Center"
                FontWeight="Bold"
                Foreground="White"
                Text="{Binding Title}" />
        </Grid>

        <!--  깜빡이는 배경(전체 스크린)  -->
        <Border
            x:Name="RootBorder"
            Grid.Row="1"
            Background="{DynamicResource RootBrush}"
            Opacity="{Binding Opacity1}" />

        <!--  본문 영역  -->
        <Grid Grid.Row="1">
            <!--  카드 레이아웃 모드 (UseContentCard = true)  -->
            <Border
                x:Name="CardBorder"
                Width="600"
                MaxWidth="600"
                Padding="24"
                HorizontalAlignment="Center"
                VerticalAlignment="Center"
                Background="#1A000000"
                CornerRadius="16"
                Visibility="{Binding UseContentCard, Converter={StaticResource BoolToVisibility}}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <!--  타이틀(중앙)  -->
                    <TextBlock
                        Grid.Row="0"
                        Margin="0,0,0,16"
                        HorizontalAlignment="Center"
                        FontSize="{Binding TitleFontSizeValue}"
                        FontWeight="Black"
                        Foreground="{DynamicResource RootForeground}"
                        Text="{Binding Title}"
                        TextAlignment="Center" />

                    <!--  콘텐츠 or 메시지  -->
                    <Grid Grid.Row="1">
                        <ContentPresenter
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center"
                            Content="{Binding Content}" />
                        <TextBlock
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center"
                            FontSize="{Binding MessageFontSizeValue}"
                            Foreground="{DynamicResource RootForeground}"
                            Text="{Binding Message}"
                            TextAlignment="Center"
                            TextWrapping="Wrap">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Visibility" Value="Collapsed" />
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding Content}" Value="{x:Null}">
                                            <Setter Property="Visibility" Value="Visible" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>
                    </Grid>

                    <!--  버튼  -->
                    <StackPanel
                        Grid.Row="2"
                        Margin="0,24,0,0"
                        HorizontalAlignment="Center"
                        Orientation="Horizontal">
                        <StackPanel.Style>
                            <Style TargetType="StackPanel">
                                <Style.Triggers>
                                    <!--  둘 다 비거나 null일 경우 StackPanel 전체 숨김  -->
                                    <MultiDataTrigger>
                                        <MultiDataTrigger.Conditions>
                                            <Condition Binding="{Binding OkText}" Value="" />
                                            <Condition Binding="{Binding CancelText}" Value="" />
                                        </MultiDataTrigger.Conditions>
                                        <Setter Property="Visibility" Value="Collapsed" />
                                    </MultiDataTrigger>
                                    <MultiDataTrigger>
                                        <MultiDataTrigger.Conditions>
                                            <Condition Binding="{Binding OkText}" Value="{x:Null}" />
                                            <Condition Binding="{Binding CancelText}" Value="{x:Null}" />
                                        </MultiDataTrigger.Conditions>
                                        <Setter Property="Visibility" Value="Collapsed" />
                                    </MultiDataTrigger>
                                </Style.Triggers>
                            </Style>
                        </StackPanel.Style>

                        <Button
                            x:Name="OkButton"
                            Width="160"
                            Height="44"
                            Margin="0,0,12,0"
                            Command="{Binding OkCommand}"
                            Content="{Binding OkText}">
                            <Button.Style>
                                <Style TargetType="Button">
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding OkText}" Value="">
                                            <Setter Property="Visibility" Value="Collapsed" />
                                        </DataTrigger>
                                        <DataTrigger Binding="{Binding OkText}" Value="{x:Null}">
                                            <Setter Property="Visibility" Value="Collapsed" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Button.Style>
                        </Button>

                        <Button
                            Width="160"
                            Height="44"
                            Command="{Binding CancelCommand}"
                            Content="{Binding CancelText}">
                            <Button.Style>
                                <Style TargetType="Button">
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding CancelText}" Value="">
                                            <Setter Property="Visibility" Value="Collapsed" />
                                        </DataTrigger>
                                        <DataTrigger Binding="{Binding CancelText}" Value="{x:Null}">
                                            <Setter Property="Visibility" Value="Collapsed" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Button.Style>
                        </Button>
                    </StackPanel>
                </Grid>
            </Border>

            <!--  카드 없이 UserControl 그대로 쓰는 모드 (UseContentCard = false)  -->
            <ContentPresenter
                x:Name="RawContentPresenter"
                HorizontalAlignment="Center"
                VerticalAlignment="Center"
                Content="{Binding Content}"
                Visibility="{Binding UseContentCard, Converter={StaticResource InverseBoolToVisibility}}" />
        </Grid>
    </Grid>
</Window>
